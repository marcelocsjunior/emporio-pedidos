DJANGO_SECRET_KEY=troque-por-uma-chave-forte
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=
DJANGO_TIME_ZONE=America/Sao_Paulo

# Central Inteligente — segura por padrão: desativada e em modo sombra.
AI_ENABLED=0
AI_MODE=shadow
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
AI_PROMPT_VERSION=mvp-ia-01-v1
AI_TIMEOUT_SECONDS=60
AI_POLL_SECONDS=900
AI_MAX_ATTEMPTS=5
AI_RETENTION_DAYS=365

# Produção: preencha todas as variáveis abaixo para habilitar PostgreSQL.
POSTGRES_DB=emporio_pedidos
POSTGRES_USER=emporio_pedidos
POSTGRES_PASSWORD=
POSTGRES_HOST=
POSTGRES_PORT=5432
